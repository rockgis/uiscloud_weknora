# 사용 설명
# 1. 이 파일을 .env로 복사하세요
# 2. 모든 플레이스홀더를 실제 값으로 교체하세요
# 3. .env 파일이 버전 관리 시스템에 커밋되지 않도록 하세요

# gin 모드
# 옵션: debug(개발 모드, 상세 로그), release(프로덕션 모드)
GIN_MODE=debug

# Ollama 서비스의 기본 URL, 로컬/다른 서버에서 실행 중인 Ollama 서비스에 연결
OLLAMA_BASE_URL=http://host.docker.internal:11434

# 스토리지 설정
# 메인 데이터베이스 유형(postgres/mysql)
DB_DRIVER=postgres

# 벡터 스토리지 유형(postgres/elasticsearch_v7/elasticsearch_v8/qdrant)
RETRIEVE_DRIVER=postgres

# 파일 스토리지 유형(local/minio/cos)
STORAGE_TYPE=local

# 스트림 처리 백엔드(memory/redis)
STREAM_MANAGER_TYPE=redis

# 애플리케이션 서비스 포트, 기본값 8080
APP_PORT=8080

# 프론트엔드 서비스 포트, 기본값 80
FRONTEND_PORT=80

# 문서 파싱 모듈 포트, 기본값 50051
DOCREADER_PORT=50051

# 데이터베이스 사용자 이름
DB_USER=postgres

# 데이터베이스 비밀번호
DB_PASSWORD=postgres123!@#

# 데이터베이스 이름
DB_NAME=uiscloud_weknora

# redis를 스트림 처리 백엔드로 사용하는 경우, 다음 파라미터를 설정해야 합니다
# Redis 비밀번호, 비밀번호가 설정되지 않은 경우 비워둘 수 있습니다
REDIS_PASSWORD=redis123!@#

# Redis 데이터베이스 인덱스, 기본값 0
REDIS_DB=0

# Redis 키 접두사, 네임스페이스 격리에 사용
REDIS_PREFIX=stream:

# 로컬 스토리지 사용 시, 파일이 저장될 기본 디렉토리 경로
LOCAL_STORAGE_BASE_DIR=./data/files

# 더티 데이터 자동 복구 여부
AUTO_RECOVER_DIRTY=true

TENANT_AES_KEY=weknorarag-api-key-secret-secret

# 지식 그래프 구축 및 검색 활성화 여부 (구축 단계에서 LLM 호출 필요, 시간이 오래 걸림)
ENABLE_GRAPH_RAG=false


# 프론트엔드 로그인 토큰 갱신을 위한 JWT_SECRET 설정
JWT_SECRET=weknora-jwt-secret

# MinIO 포트
# MINIO_PORT=9000

# MinIO 콘솔 포트
# MINIO_CONSOLE_PORT=9001

# Embedding 동시 처리 수, 429 오류 발생 시 이 값을 줄이세요
CONCURRENCY_POOL_SIZE=5

# ElasticSearch를 벡터 스토리지로 사용하는 경우, 다음 파라미터를 설정해야 합니다
# ElasticSearch 주소, 예: http://localhost:9200
# ELASTICSEARCH_ADDR=your_elasticsearch_addr

# ElasticSearch 사용자 이름, 인증이 필요한 경우
# ELASTICSEARCH_USERNAME=your_elasticsearch_username

# ElasticSearch 비밀번호, 인증이 필요한 경우
# ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# ElasticSearch 인덱스 이름, 벡터 데이터 저장에 사용
# ELASTICSEARCH_INDEX=uiscloud_weknora

# Qdrant를 벡터 스토리지로 사용하는 경우, 다음 파라미터를 설정해야 합니다
# Qdrant 서비스 호스트 주소
# QDRANT_HOST=localhost

# Qdrant 서비스 포트
# QDRANT_PORT=6334

# Qdrant 컬렉션 이름, 벡터 데이터 저장에 사용
# QDRANT_COLLECTION=weknora_embeddings

# Qdrant API 키, 인증이 필요한 경우 (선택사항)
# QDRANT_API_KEY=your_qdrant_api_key

# TLS 암호화 연결 활성화 여부 (선택사항, 기본값 false)
# QDRANT_USE_TLS=false

# MinIO를 파일 스토리지로 사용하는 경우, 다음 파라미터를 설정해야 합니다
# MinIO 액세스 키
# MINIO_ACCESS_KEY_ID=your_minio_access_key

# MinIO 시크릿 키
# MINIO_SECRET_ACCESS_KEY=your_minio_secret_key

# MinIO 버킷 이름, 파일 저장에 사용
# MINIO_BUCKET_NAME=your_minio_bucket_name

# 텐센트 클라우드 COS를 파일 스토리지로 사용하는 경우, 다음 파라미터를 설정해야 합니다
# 텐센트 클라우드 COS 액세스 키 ID
# COS_SECRET_ID=your_cos_secret_id

# 텐센트 클라우드 COS 시크릿 키
# COS_SECRET_KEY=your_cos_secret_key

# 텐센트 클라우드 COS 리전, 예: ap-guangzhou
# COS_REGION=your_cos_region

# 텐센트 클라우드 COS 버킷 이름
# COS_BUCKET_NAME=your_cos_bucket_name

# 텐센트 클라우드 COS 앱 ID
# COS_APP_ID=your_cos_app_id

# 텐센트 클라우드 COS 경로 접두사, 파일 저장에 사용
# COS_PATH_PREFIX=your_cos_path_prefix

# COS_ENABLE_OLD_DOMAIN=true는 이전 도메인 형식을 활성화, 기본값 true
COS_ENABLE_OLD_DOMAIN=true

# 네트워크 연결 파싱에 웹 프록시를 사용하는 경우, 다음 파라미터를 설정해야 합니다
# WEB_PROXY=your_web_proxy

# Neo4j 활성화 여부 (true 시 docker-compose --profile neo4j 로 자동 시작)
NEO4J_ENABLE=true

# Neo4j 사용자 이름
NEO4J_USERNAME=neo4j

# Neo4j 비밀번호
NEO4J_PASSWORD=password
